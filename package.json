{
  "name": "flight-tracker",
  "version": "1.0.0",
  "description": "Monitora passagens baratas e notifica no Telegram",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "webhook": "ts-node src/webhook.ts",
    "news": "ts-node src/index-news.ts",
    "offers": "ts-node src/index-offers.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:webhook": "node dist/webhook.js",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node src/migrate-history.ts",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!src/index-news.ts",
      "!src/index-offers.ts",
      "!src/webhook.ts",
      "!src/config.ts",
      "!src/migrate-history.ts",
      "!src/scripts/**",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 79,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "axios-mock-adapter": "^2.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
