# Filtros avançados (todos opcionais)
# Lista de companhias permitidas — separadas por vírgula. Deixe em branco para aceitar todas.
# AIRLINES_WHITELIST=LATAM,GOL
# Número máximo de escalas (0 = só voos diretos). Deixe em branco para aceitar qualquer número.
# MAX_STOPS=0
# Duração máxima do voo em horas. Deixe em branco para aceitar qualquer duração.
# MAX_DURATION_HOURS=3
