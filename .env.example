# APIs
# Apify — suporte a até 5 tokens. Se um ficar sem créditos, o próximo é tentado automaticamente.
# APIFY_API_TOKEN (sem número) também funciona como APIFY_API_TOKEN_1 para compatibilidade.
APIFY_API_TOKEN_1=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# APIFY_API_TOKEN_2=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# APIFY_API_TOKEN_3=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# APIFY_API_TOKEN_4=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# APIFY_API_TOKEN_5=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
APIFY_ACTOR_ID=johnvc~google-flights-data-scraper-flight-and-price-search
RAPIDAPI_KEY=your_rapidapi_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Rota
# Use ORIGIN para uma única origem ou ORIGINS para múltiplas (ORIGINS tem prioridade).
# ORIGINS=BSB,GRU varre todas as combinações nos dois sentidos (útil para quem quer volta barata).
ORIGIN=BSB
# ORIGINS=BSB,GRU
DESTINATIONS=GRU,SDL,FOR
DEPARTURE_DATE=2025-08-15
DATE_RANGE_DAYS=30
TRIP_TYPE=one-way
# RETURN_DATE=2025-08-22  # obrigatório apenas se TRIP_TYPE=round-trip

# Passageiros
ADULTS=1
CHILDREN=0

# Filtro de preço (usado no tracker e convertido para USD ao enviar ao Apify)
MAX_PRICE_BRL=300

# Filtros avançados (todos opcionais)
# Lista de companhias permitidas — separadas por vírgula. Filtro aplicado no tracker.
# AIRLINES_WHITELIST=LATAM,GOL
# Número máximo de escalas — passado diretamente ao Apify (0 = só voos diretos).
# MAX_STOPS=0
# Duração máxima do voo em horas. Filtro aplicado no tracker.
# MAX_DURATION_HOURS=3
